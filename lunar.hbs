{{!-- Schema.org — FAQPage                                             --}}
{{!-- ================================================================ --}}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": "{{@site.url}}/calendar/#faq",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What are the main holy days of the Unification movement?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Unification movement observes six principal Holy Days: God's Day, True Parents' Day, True Children's Day, the Day of All True Things, the Day of Victory of Love, and Foundation Day. Each marks a specific providential milestone — a moment when a spiritual standard was established in human history. Observed according to the Heavenly Calendar (lunar cycle), their dates shift each year relative to the solar calendar."
      }
    },
    {
      "@type": "Question",
      "name": "What is God's Day?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "God's Day was inaugurated by Rev. Moon on January 1, 1968, at 3 a.m. at the Unification Church headquarters in Cheongpadong, Seoul, Korea. It was the first day in history when God could be honored in His own right — not as a distant ruler, but as a Parent whose children had returned to Him through restored love. In 1994, the name was updated to True God's Day to reflect a deeper understanding of God's nature as the Heavenly Parent."
      }
    },
    {
      "@type": "Question",
      "name": "What is Foundation Day?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Foundation Day was proclaimed on January 13, 2013 (Heavenly Calendar), marking the formal inauguration of Cheon Il Guk: the Kingdom of Heaven on earth and in heaven. It is considered the most historically significant date in the entire restoration providence — the culmination of all the preparation, suffering, and indemnity conditions laid over thousands of years of human history."
      }
    },
    {
      "@type": "Question",
      "name": "What is the Day of Victory of Love?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Day of Victory of Love was established on January 2, 1984, following the death of Rev. Moon's son Heung Jin Nim in a traffic accident on December 22, 1983. Rather than being observed as a day of mourning, Rev. Moon declared it a day of victory — teaching that his son's death, embraced with love and without resentment, had broken Satan's claim over human lineage in a way that could not otherwise have been achieved."
      }
    },
    {
      "@type": "Question",
      "name": "When did True Parents' Day, True Children's Day, and the Day of All True Things begin?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "True Parents' Day was first established on April 1, 1960 (lunar calendar), shortly after Rev. Moon's Holy Wedding with Hak Ja Han on March 1, 1960. True Children's Day followed in October 1960. The Day of All True Things came next, in June 1963 — each day building on the one before, completing the four-position foundation step by step."
      }
    },
    {
      "@type": "Question",
      "name": "What is Ahn Shil Il?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ahn Shil Il — meaning 'Day of Sabbath' or 'Day of Rest' — is a weekly observance in the Unification movement marked in blue on the Heavenly Calendar. Ahn Shil Il is understood as a day of spiritual restoration: families gather, recite the Family Pledge, engage in Hoon Dok Hae, and rest from ordinary labor as a reflection of their alignment with God's creative rhythm."
      }
    },
    {
      "@type": "Question",
      "name": "What is the Heavenly Calendar?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Heavenly Calendar is a lunar calendar used within the Unification movement to track the dates of holy days, Ahn Shil Il, and other providential observances. Most key dates were originally established lunar, so their Gregorian equivalents shift each year. By observing the Heavenly Calendar, members participate in the providential rhythm consciously — ordering their weeks around Ahn Shil Il and their year around six holy days."
      }
    }
  ]
}
</script>

{{!-- Lunar calendar library — self-hosted (mirrored from korean-lunar-calendar@0.3.6 / MIT licensed) --}}
<script src="{{asset "js/korean-lunar-calendar.min.js"}}"></script>

<div class="lunar-wrap">

  {{!-- ============================================================ --}}
  {{!-- HERO                                                          --}}
  {{!-- ============================================================ --}}
  <section class="hc-hero">
    <p class="hc-eyebrow">Holy Days &amp; Calendar</p>
    <h1 class="hc-title">Heavenly Calendar</h1>
    <p class="hc-motto">
      In the 14th year of Cheon Il Guk, when we attend the Creator Heavenly Parent substantially,
      let us, the blessed families around the world, become true sons and daughters of Cheon Il Guk
      who fulfill our responsibility as the chosen people in unity with True Parents.
    </p>
  </section>

  {{!-- ============================================================ --}}
  {{!-- TODAY CARD                                                   --}}
  {{!-- ============================================================ --}}
  <section class="lunar-today" aria-live="polite" aria-label="Today">
    <div class="lcube">
      <span class="lcube-num" id="lcubeNum">—</span>
      <span class="lcube-lbl">Heavenly</span>
    </div>
    <div class="linfo">
      <p class="lsolar" id="lsolarDate">—</p>
      <span class="lera" id="cheonYearLabel"></span>
      <div class="levents" id="lspecial" aria-live="polite"></div>
    </div>
  </section>

  {{!-- ============================================================ --}}
  {{!-- MONTH NAV                                                    --}}
  {{!-- ============================================================ --}}
  <nav class="lunar-nav" aria-label="Month navigation">
    <button id="prevMonth" class="navbtn" aria-label="Previous month">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M15 6l-6 6 6 6"/></svg>
    </button>
    <div id="monthLabel" class="monthlabel" aria-live="polite">—</div>
    <button id="nextMonth" class="navbtn" aria-label="Next month">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M9 6l6 6-6 6"/></svg>
    </button>
  </nav>

  {{!-- ============================================================ --}}
  {{!-- CALENDAR GRID                                                --}}
  {{!-- ============================================================ --}}
  <section class="lunar-grid" role="grid" aria-label="Gregorian calendar">
    <div class="grid-scroll">
      <div class="dows" role="row">
        <div class="dow" role="columnheader" abbr="Monday">Mon</div>
        <div class="dow" role="columnheader" abbr="Tuesday">Tue</div>
        <div class="dow" role="columnheader" abbr="Wednesday">Wed</div>
        <div class="dow" role="columnheader" abbr="Thursday">Thu</div>
        <div class="dow" role="columnheader" abbr="Friday">Fri</div>
        <div class="dow weekend" role="columnheader" abbr="Saturday">Sat</div>
        <div class="dow weekend" role="columnheader" abbr="Sunday">Sun</div>
      </div>
      <div id="grid" class="cells" role="rowgroup"></div>
    </div>
  </section>

  {{!-- ============================================================ --}}
  {{!-- LEGEND                                                       --}}
  {{!-- ============================================================ --}}
  <section class="legend" aria-label="Legend">
    <span class="legend-item">
      <span class="legend-swatch blue" aria-hidden="true"></span>
      <strong class="c-blue">Ahn Shil Il</strong>
      <span class="legend-note">weekly day of rest (every 8th day)</span>
    </span>
    <span class="legend-item">
      <span class="legend-swatch red" aria-hidden="true"></span>
      <strong class="c-red">Holy Day</strong>
      <span class="legend-note">official sacred observance</span>
    </span>
  </section>

  {{!-- ============================================================ --}}
  {{!-- UPCOMING EVENTS                                              --}}
  {{!-- ============================================================ --}}
  <section class="upcoming-section" aria-labelledby="upcoming-heading">
    <header class="upcoming-head">
      <h2 id="upcoming-heading">Upcoming</h2>
      <span class="upcoming-hint">Next 60 days</span>
    </header>
    <div class="upcoming-list" id="upcomingList"></div>
  </section>

  {{!-- ============================================================ --}}
  {{!-- EMBED CTA                                                    --}}
  {{!-- ============================================================ --}}
  <section class="calendar-embed-cta">
    <button id="openEmbedCode" class="embed-btn" type="button">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
      Embed this calendar on your site
    </button>

    <div id="embedDialog" class="embed-dialog" hidden role="dialog" aria-modal="true" aria-labelledby="embedDialogTitle">
      <div class="embed-dialog-inner">
        <div class="embed-dialog-header">
